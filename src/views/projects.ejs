<%- include('partials/header') %>
<main>
  <h1>
    <%= title %>
  </h1>
  <p>Here are some of our upcoming service projects:</p>
  <ul>
    <% projects.forEach(project => { %>
    <li>
      <strong
        ><%= new Date(project.project_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>:
        <a href="/project/<%= project.project_id %>"><%= project.title %></a>
        (<em
          ><a href="/organization/<%= project.organization_id %>"
            ><%= project.organization_name %></a
          ></em
        >)</strong
      >
    </li>
    <% }); %>
  </ul>
</main>
<%- include('partials/footer') %>
