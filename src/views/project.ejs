<%- include('partials/header') %>
<main>
  <h1>
    <%= title %>
  </h1>

  <h2><%= project.title %></h2>
  <p>Description: <%= project.description %></p>
  <p>
    Date: <%= new Date(project.project_date).toLocaleDateString('en-US', { year:
    'numeric', month: 'long', day: 'numeric' }) %>
  </p>
  <p>Location: <%= project.location %></p>
  <p>
    Organization:
    <a href="/organization/<%= project.organization_id %>"
      ><%= project.organization_name %></a
    >
  </p>
  <p>
    Categories: <% categories.forEach((category, index) => { %>
    <a href="/category/<%= category.category_id %>"><%= category.name %></a
    ><% if (index < categories.length - 1) { %>,
    <% } %>
    <% }); %>
  </p>
</main>
<%- include('partials/footer') %>
