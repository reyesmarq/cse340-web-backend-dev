<%- include('partials/header') %>
<main>
  <h1>
    <%= title %>
  </h1>
  <h2>Service Project Categories</h2>
  <ul class="categories-list">
    <% categories.forEach(category => { %>
    <li>
      <a href="/category/<%= category.category_id %>"><%= category.name %></a>
    </li>
    <% }); %>
  </ul>
</main>
<%- include('partials/footer') %>
